# ── Procurement Flow Specialist BD — Environment Configuration ────────────

# Application
APP_NAME=Procurement Flow Specialist BD
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Backend Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://procurementflow:procurementflow@localhost:5432/procurementflow
BOQ_DATABASE_URL=postgresql+asyncpg://procurementflow:procurementflow@localhost:5432/procurementflow

# Redis (Celery Broker)
REDIS_URL=redis://localhost:6379/0

# MinIO (File Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=procurementflow
MINIO_SECRET_KEY=procurementflow123
MINIO_BUCKET=procurementflow-tenders
MINIO_SECURE=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# AI Providers
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AI Model Selection (auto, openai, anthropic, ollama)
AI_ENGINE=auto

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_PRO=price_your_pro_plan_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_plan_id

# SMTP / Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFICATION_FROM=noreply@procurementflow.com.bd
NOTIFICATION_TO=admin@procurementflow.com.bd

# Storage Paths
BASE_DIR=./runtime
TENDERAI_DIR=./tenderai_outputs
BOQ_BASE_DIR=./runtime

# eGP Scraper
EGP_BASE_URL=https://www.eprocure.gov.bd
EGP_REQUEST_DELAY=2.0
EGP_MAX_RETRIES=3
EGP_ENABLE_SCRAPER=true

# Celery Worker
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=false
SQL_ECHO=false

# Feature Flags
ENABLE_TENDER_RADAR=true
ENABLE_AWARD_SCRAPING=true
ENABLE_EMAIL_ALERTS=false
ENABLE_DEMO_MODE=true
ENABLE_STRIPE_PAYMENTS=false

# Rate Limits
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Security
CORS_ALLOW_CREDENTIALS=true
HASH_ALGORITHM=SHA256
TOKEN_EXPIRE_HOURS=24
MAX_LOGIN_ATTEMPTS=5
