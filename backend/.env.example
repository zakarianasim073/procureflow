# ── Procurement Flow Specialist BD — Backend Environment ──────────────────

APP_NAME=Procurement Flow Specialist BD
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://procurementflow:procurementflow@localhost:5432/procurementflow

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=procurementflow
MINIO_SECRET_KEY=procurementflow123
MINIO_BUCKET=procurementflow-tenders

# Auth
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_ENGINE=auto

# Payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM=noreply@procurementflow.com.bd

# Storage
BASE_DIR=./runtime
TENDERAI_DIR=./tenderai_outputs

# Frontend
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Celery
CELERY_WORKER_CONCURRENCY=4
SQL_ECHO=false

# eGP
EGP_BASE_URL=https://www.eprocure.gov.bd
EGP_REQUEST_DELAY=2.0
EGP_MAX_RETRIES=3

# Feature Flags
ENABLE_TENDER_RADAR=true
ENABLE_AWARD_SCRAPING=true
ENABLE_DEMO_MODE=true
ENABLE_STRIPE_PAYMENTS=false
