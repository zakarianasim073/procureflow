# ── Procurement Flow Specialist BD — Windows 11 Configuration ────────────
# Copy this to .env or let setup.bat create it automatically

# Application
APP_NAME=Procurement Flow Specialist BD
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

# Database — SQLite (no PostgreSQL needed for development)
DATABASE_URL=sqlite+aiosqlite:///./runtime/db/procureflow.db

# Storage Paths
BASE_DIR=./runtime
TENDERAI_DIR=%USERPROFILE%/Documents/tenderai

# JWT Authentication
JWT_SECRET=procurement-flow-windows-dev-key-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# AI Providers — set your keys or leave blank for demo mode
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local LLM) — optional
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_ENGINE=auto

# eGP Scraper
EGP_BASE_URL=https://www.eprocure.gov.bd
EGP_EMAIL=
EGP_PASSWORD=
EGP_ENABLE_SCRAPER=true
EGP_REQUEST_DELAY=2.0
EGP_MAX_RETRIES=3
ENABLE_TENDER_RADAR=true
ENABLE_DEMO_MODE=true

# Feature Flags
ENABLE_EMAIL_ALERTS=false
ENABLE_STRIPE_PAYMENTS=false

# Rate Limits
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── eGP Portal Credentials ──────────────────────────────────────
# Set your eGP Bangladesh portal credentials for authenticated features.
# Without these, the system works in PUBLIC-ONLY mode.
EGP_EMAIL=
EGP_PASSWORD=
